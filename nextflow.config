nextflow.enable.dsl = 2

def joinSlurmOptions(params) {
  [
    params.slurm_account ? "--account=${params.slurm_account}" : null,
    params.slurm_qos ? "--qos=${params.slurm_qos}" : null,
    params.slurm_constraint ? "--constraint=${params.slurm_constraint}" : null,
    params.slurm_cluster_options ? params.slurm_cluster_options : null,
  ].findAll { it != null && it.toString().trim() }.join(' ')
}

params {
  fasta_dir        = ""
  working_dir      = ""
  ref_dir          = ""
  filter_size      = "2500"
  min_genome_size  = 100000
  max_genome_size  = 15000000
  completeness     = 0
  contamination    = 10
  qscore_min       = 0
  checkm_cpus      = 16
  checkm_batch_size = 2000
  checkm_max_forks = 1
  trnascan_cpus    = 1
  trnascan_max_forks = 16
  gtdbtk_cpus      = 16
  gunc_cpus        = 16
  max_forks        = 16
  checkm_data_path = ""
  gtdbtk_data_path = ""
  gunc_db          = ""
  gtdbtk_package_url = "https://data.gtdb.ecogenomic.org/releases/release220/220.0/auxillary_files/gtdbtk_package/full_package/gtdbtk_r220_data.tar.gz"
  slurm_account    = ""
  slurm_partition  = ""
  slurm_qos        = ""
  slurm_constraint = ""
  slurm_time       = ""
  slurm_medium_partition = ""
  slurm_large_partition = ""
  slurm_queue_size = 100
  slurm_submit_rate_limit = "10 sec"
  slurm_cluster_options = ""
  small_job_memory = "4 GB"
  small_job_time   = "4h"
  medium_job_memory = "8 GB"
  medium_job_time   = "12h"
  reference_setup_memory = "8 GB"
  reference_setup_time   = "12h"
  trnascan_memory = "4 GB"
  trnascan_time   = "8h"
  checkm_memory   = "32 GB"
  checkm_time     = "24h"
  gtdbtk_memory   = "64 GB"
  gtdbtk_time     = "24h"
  gunc_memory     = "32 GB"
  gunc_time       = "24h"
  debug            = false
}

conda {
  enabled = true
  useMamba = true
  // Keep solver-created env prefixes off NFS work dirs by default.
  cacheDir = "${projectDir}/.nextflow-conda"
  createTimeout = '2h'
}

profiles {
  conda {
    conda.enabled = true
  }
  mamba {
    conda.enabled = true
    conda.useMamba = true
  }
  slurm {
    executor {
      queueSize = params.slurm_queue_size
      submitRateLimit = params.slurm_submit_rate_limit
    }
    process {
      executor = 'slurm'
      time = params.small_job_time
      memory = params.small_job_memory
      clusterOptions = joinSlurmOptions(params)

      withName: 'TRNASCAN' {
        memory = params.trnascan_memory
        time = params.trnascan_time
      }

      withName: 'CHECKM_SINGLE' {
        memory = params.checkm_memory
        time = params.checkm_time
      }

      withName: 'GTDBTK' {
        memory = params.gtdbtk_memory
        time = params.gtdbtk_time
      }

      withName: 'GUNC' {
        memory = params.gunc_memory
        time = params.gunc_time
      }

      withName: 'SETUP_GTDBTK_DB|SETUP_GUNC_DB|SETUP_CHECKM_DB' {
        memory = params.reference_setup_memory
        time = params.reference_setup_time
      }

      withName: 'MERGE_MASTER|DEDUPE|QSCORE' {
        memory = params.medium_job_memory
        time = params.medium_job_time
      }
    }
  }
  debug {
    process.echo = true
    trace.enabled = true
    timeline.enabled = true
    report.enabled = true
  }
}

process {
  cpus = 1
  errorStrategy = 'terminate'
  shell = ['/bin/bash', '-euo', 'pipefail']
}

report {
  overwrite = true
}

timeline {
  overwrite = true
}
