nextflow.enable.dsl = 2

def joinSlurmOptions(params) {
  [
    params.slurm_nodes ? "--nodes=${params.slurm_nodes}" : null,
    params.slurm_account ? "--account=${params.slurm_account}" : null,
    params.slurm_qos ? "--qos=${params.slurm_qos}" : null,
    params.slurm_constraint ? "--constraint=${params.slurm_constraint}" : null,
    params.slurm_cluster_options ? params.slurm_cluster_options : null,
  ].findAll { it != null && it.toString().trim() }.join(' ')
}

params {
  fasta_dir        = ""
  working_dir      = ""
  ref_dir          = ""
  filter_size      = "2500 5000 10000 20000"
  min_genome_size  = 100000
  max_genome_size  = 15000000
  completeness     = 0
  contamination    = 10
  qscore_min       = -1000000
  checkm_cpus      = 24
  checkm_batch_size = 1000
  checkm_max_forks = 250
  trnascan_cpus    = 1
  trnascan_max_forks = 250
  gtdbtk_cpus      = 24
  gtdbtk_batch_size = 1000
  gtdbtk_max_forks = 250
  gunc_cpus        = 24
  atlas_enabled    = true
  atlas_prefix     = "genome_quality"
  atlas_group_column = "Phylum"
  atlas_sample_column = ""
  atlas_matched_samples_only = false
  atlas_top_n_groups = 1000
  atlas_compare_columns = ""
  atlas_compare_map = ""
  atlas_compare_map_key = ""
  atlas_ani_compare_columns = ""
  atlas_ani_results = ""
  atlas_ani_genome_dir = ""
  atlas_ani_fasta_column = ""
  atlas_ani_fasta_exts = ".fasta,.fa,.fna,.fasta.gz,.fa.gz,.fna.gz"
  atlas_ani_threshold = 99.0
  atlas_ani_af_threshold = 0.5
  atlas_ani_threads = 25
  atlas_ani_top_overlaps = 15
  atlas_cpus       = atlas_ani_threads
  atlas_memory     = "64 GB"
  atlas_time       = "24h"
  max_forks        = 250
  checkm_data_path = ""
  gtdbtk_data_path = ""
  gunc_db          = ""
  gtdbtk_package_url = ""
  slurm_account    = "st-shallam-1"
  slurm_partition  = ""
  slurm_qos        = ""
  slurm_constraint = ""
  slurm_nodes      = 1
  slurm_time       = ""
  slurm_medium_partition = ""
  slurm_large_partition = ""
  slurm_queue_size = 250
  slurm_submit_rate_limit = "10 sec"
  slurm_cluster_options = ""
  small_job_memory = "4 GB"
  small_job_time   = "4h"
  medium_job_memory = "8 GB"
  medium_job_time   = "12h"
  reference_setup_memory = "8 GB"
  reference_setup_time   = "12h"
  trnascan_memory = "32 GB"
  trnascan_time   = "8h"
  checkm_memory   = "128 GB"
  checkm_time     = "24h"
  gtdbtk_memory   = "128 GB"
  gtdbtk_time     = "24h"
  gunc_memory     = "128 GB"
  gunc_time       = "24h"
  debug            = false
}

conda {
  enabled = true
  useMamba = true
  // Keep solver-created env prefixes off NFS work dirs by default.
  cacheDir = "${projectDir}/.nextflow-conda"
  createTimeout = '2h'
}

profiles {
  conda {
    conda.enabled = true
  }
  mamba {
    conda.enabled = true
    conda.useMamba = true
  }
  slurm {
    executor {
      queueSize = params.slurm_queue_size
      submitRateLimit = params.slurm_submit_rate_limit
    }
    process {
      executor = 'slurm'
      time = params.small_job_time
      memory = params.small_job_memory
      clusterOptions = joinSlurmOptions(params)

      withName: 'TRNASCAN' {
        memory = params.trnascan_memory
        time = params.trnascan_time
      }

      withName: 'CHECKM_SINGLE' {
        memory = params.checkm_memory
        time = params.checkm_time
      }

      withName: 'GTDBTK' {
        memory = params.gtdbtk_memory
        time = params.gtdbtk_time
      }

      withName: 'GUNC' {
        memory = params.gunc_memory
        time = params.gunc_time
      }

      withName: 'SETUP_GTDBTK_DB|SETUP_GUNC_DB|SETUP_CHECKM_DB' {
        memory = params.reference_setup_memory
        time = params.reference_setup_time
      }

      withName: 'GENOME_QUALITY_ATLAS' {
        memory = params.atlas_memory
        time = params.atlas_time
      }

      withName: 'MERGE_MASTER|DEDUPE|QSCORE' {
        memory = params.medium_job_memory
        time = params.medium_job_time
      }
    }
  }
  debug {
    process.echo = true
    trace.enabled = true
    timeline.enabled = true
    report.enabled = true
  }
}

process {
  cpus = 1
  errorStrategy = 'terminate'
  shell = ['/bin/bash', '-euo', 'pipefail']
}

report {
  overwrite = true
}

timeline {
  overwrite = true
}
